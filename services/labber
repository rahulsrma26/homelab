#!/usr/bin/env bash
# labber — homelab service manager
set -euo pipefail

VERSION="2.0.2"
REPO="https://github.com/rahulsrma26/homelab.git"
LABBER_URL="https://raw.githubusercontent.com/rahulsrma26/homelab/refs/heads/main/services/labber"
LABBER_BIN="/usr/local/bin/labber"
SERVICE_BASE="/opt/homelab/services"

# ── colours ───────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
    R=$'\033[0;31m' G=$'\033[0;32m' Y=$'\033[1;33m'
    B=$'\033[0;34m' C=$'\033[0;36m' W=$'\033[1m' N=$'\033[0m'
else
    R='' G='' Y='' B='' C='' W='' N=''
fi

die()  { echo -e "${R}error: $*${N}" >&2; exit 1; }
info() { echo -e "${C}:: $*${N}"; }
ok()   { echo -e "${G}✓ $*${N}"; }
warn() { echo -e "${Y}! $*${N}"; }

# ── helpers ───────────────────────────────────────────────────────────────────

check_deps() {
    local miss=()
    for cmd in docker git; do command -v "$cmd" &>/dev/null || miss+=("$cmd"); done
    (( ${#miss[@]} == 0 )) || die "missing: ${miss[*]}"
}

svc_dir() { echo "$SERVICE_BASE/$1"; }

need_svc() {
    local dir; dir=$(svc_dir "$1")
    [[ -f "$dir/docker-compose.yml" ]] || die "'$1' not installed (no docker-compose.yml at $dir)"
    echo "$dir"
}

list_installed() {
    [[ -d "$SERVICE_BASE" ]] || return 0
    find "$SERVICE_BASE" -maxdepth 3 -name "docker-compose.yml" -exec dirname {} \; \
        | sed "s|^$SERVICE_BASE/||" | sort
}

pick() {
    local prompt="$1"; shift; local items=("$@")
    (( ${#items[@]} > 0 )) || die "nothing to pick from"
    echo -e "\n${W}${prompt}${N}" >&2
    for i in "${!items[@]}"; do printf "  %2d) %s\n" "$((i+1))" "${items[$i]}" >&2; done
    echo >&2
    local n
    while true; do
        read -rp "choice [1-${#items[@]}]: " n
        [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= ${#items[@]} )) && break
        echo -e "${Y}! invalid choice${N}" >&2
    done
    echo "${items[$((n-1))]}"
}

# resolve service: use CLI arg if given, else interactive pick from installed
resolve_svc() {
    if [[ -n "${1:-}" ]]; then echo "$1"; return; fi
    local svcs; mapfile -t svcs < <(list_installed)
    (( ${#svcs[@]} > 0 )) || die "no services installed under $SERVICE_BASE"
    pick "Select service:" "${svcs[@]}"
}

# ── commands ──────────────────────────────────────────────────────────────────

do_install() {
    check_deps
    local tmpdir="/tmp/homelab-deploy-$$"
    trap 'rm -rf "$tmpdir"' EXIT

    info "fetching service list from repo..."
    git clone --depth=1 --sparse --filter=blob:none -q "$REPO" "$tmpdir"
    git -C "$tmpdir" sparse-checkout set services/

    local avail; mapfile -t avail < <(
        find "$tmpdir/services" -maxdepth 3 -name "docker-compose.yml" -exec dirname {} \; \
            | sed "s|^$tmpdir/services/||" | sort
    )

    local svc="${1:-}"; [[ -n "$svc" ]] || svc=$(pick "Select service to install:" "${avail[@]}")
    local src="$tmpdir/services/$svc"
    [[ -d "$src" ]] || die "service '$svc' not found in repo"

    local dest; dest=$(svc_dir "$svc")

    if [[ -d "$dest" ]]; then
        warn "'$svc' already installed at $dest"
        local ans; read -rp "Reinstall? (overwrites config files, preserves .env) [y/N] " ans
        [[ "$ans" =~ ^[Yy]$ ]] || { info "aborted"; return; }
        (cd "$dest" && docker compose down 2>/dev/null || true)
        # back up .env, overwrite everything, restore .env
        [[ -f "$dest/.env" ]] && cp "$dest/.env" "/tmp/.labber-env-backup-$$"
        cp -r "$src/." "$dest/"
        [[ -f "/tmp/.labber-env-backup-$$" ]] && mv "/tmp/.labber-env-backup-$$" "$dest/.env"
    else
        mkdir -p "$dest"
        cp -r "$src/." "$dest/"
        if [[ -f "$dest/.env.example" && ! -f "$dest/.env" ]]; then
            cp "$dest/.env.example" "$dest/.env"
            warn ".env created from .env.example — edit it before starting"
            warn "  ${W}nano $dest/.env${N}"
            read -rp "Press Enter when ready, or Ctrl+C to abort... "
        fi
    fi

    # show README if present
    if [[ -f "$dest/README.txt" ]]; then
        echo; echo -e "${W}--- README ---${N}"
        cat "$dest/README.txt"
        echo -e "${W}--------------${N}"; echo
    fi

    info "pulling images and starting $svc..."
    (cd "$dest" && docker compose pull && docker compose up -d)
    ok "$svc is running"
    (cd "$dest" && docker compose ps)
}

do_uninstall() {
    check_deps
    local svc; svc=$(resolve_svc "${1:-}")
    local dir; dir=$(need_svc "$svc")
    warn "will stop '$svc' and delete $dir"
    local ans; read -rp "Confirm [y/N] " ans
    [[ "$ans" =~ ^[Yy]$ ]] || { info "aborted"; return; }
    (cd "$dir" && docker compose down)
    rm -rf "$dir"
    ok "'$svc' removed"
}

do_start() {
    check_deps
    local svc; svc=$(resolve_svc "${1:-}")
    local dir; dir=$(need_svc "$svc")
    info "starting $svc..."
    (cd "$dir" && docker compose start)
    ok "done"
}

do_stop() {
    check_deps
    local svc; svc=$(resolve_svc "${1:-}")
    local dir; dir=$(need_svc "$svc")
    info "stopping $svc..."
    (cd "$dir" && docker compose stop)
    ok "done"
}

do_restart() {
    check_deps
    local svc; svc=$(resolve_svc "${1:-}")
    local dir; dir=$(need_svc "$svc")
    info "restarting $svc..."
    (cd "$dir" && docker compose up -d --force-recreate)
    ok "done"
}

do_rebuild() {
    check_deps
    local svc; svc=$(resolve_svc "${1:-}")
    local dir; dir=$(need_svc "$svc")
    info "rebuilding '$svc': down → system prune → pull → up"
    (cd "$dir" && docker compose down)
    docker system prune -f
    (cd "$dir" && docker compose pull)
    (cd "$dir" && docker compose up -d)
    ok "'$svc' rebuilt and running"
    (cd "$dir" && docker compose ps)
}

do_shell() {
    check_deps
    local svc; svc=$(resolve_svc "${1:-}")
    local dir; dir=$(need_svc "$svc")
    local ctrs; mapfile -t ctrs < <(cd "$dir" && docker compose ps --format '{{.Name}}' 2>/dev/null || true)
    (( ${#ctrs[@]} > 0 )) || die "no running containers for '$svc'"
    local ctr="${ctrs[0]}"
    (( ${#ctrs[@]} > 1 )) && ctr=$(pick "Select container:" "${ctrs[@]}")
    info "entering $ctr..."
    docker exec -it "$ctr" /bin/bash 2>/dev/null || docker exec -it "$ctr" /bin/sh
}

do_logs() {
    check_deps
    local svc; svc=$(resolve_svc "${1:-}")
    local dir; dir=$(need_svc "$svc")
    (cd "$dir" && docker compose logs -f)
}

do_status() {
    check_deps
    local svc; svc=$(resolve_svc "${1:-}")
    local dir; dir=$(need_svc "$svc")
    (cd "$dir" && docker compose ps)
}

do_go() {
    local svc; svc=$(resolve_svc "${1:-}")
    need_svc "$svc" >/dev/null
    local dir; dir=$(svc_dir "$svc")
    if [[ -t 1 ]]; then
        # stdout is a terminal — not captured by shell function, cd won't happen
        info "Directory: ${W}$dir${N}"
        warn "to actually cd there, run: labber $svc go   (requires self-install + source ~/.bashrc)"
    else
        # stdout captured by shell function — just print the path for cd
        echo "$dir"
    fi
}

_install_shell_fn() {
    local target_home="$HOME"
    [[ -n "${SUDO_USER:-}" ]] && target_home="$(getent passwd "$SUDO_USER" | cut -d: -f6)"
    local rc="$target_home/.bashrc"
    local start_marker="# labber shell function"
    local end_marker="^}"
    if grep -qF "$start_marker" "$rc" 2>/dev/null; then
        local tmp; tmp=$(mktemp)
        awk "/^${start_marker}$/{skip=1} skip && /^}$/{skip=0; next} !skip" "$rc" > "$tmp"
        mv "$tmp" "$rc"
    fi
    cat >> "$rc" <<'BASHRC'

# labber shell function
labber() {
  if [[ "$2" == go ]]; then
    cd "$(/usr/local/bin/labber "$1" go)"
  else
    /usr/local/bin/labber "$@"
  fi
}
BASHRC
    ok "shell function updated in $rc"
}

_install_completion_fn() {
    local rc="${HOME}/.bashrc"
    local start_marker="# labber completion"
    local end_marker="complete -F _labber_complete labber"
    # Remove old block so we always install the latest version
    if grep -qF "$start_marker" "$rc" 2>/dev/null; then
        local tmp; tmp=$(mktemp)
        awk "/^${start_marker}$/{skip=1} skip && /^${end_marker}$/{skip=0; next} !skip" "$rc" > "$tmp"
        mv "$tmp" "$rc"
    fi
    cat >> "$rc" <<'BASHRC'

# labber completion
_labber_complete() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local arg1="${COMP_WORDS[1]}"
    local svc_cmds="uninstall start stop restart rebuild shell logs status go"
    local global_cmds="install ls clean update help"
    local svcs; svcs=$(find /opt/homelab/services -maxdepth 3 -name docker-compose.yml \
        -exec dirname {} \; 2>/dev/null | sed 's|.*/services/||' | sort)
    if [[ $COMP_CWORD -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "$global_cmds $svcs" -- "$cur") )
    elif [[ $COMP_CWORD -eq 2 && ! " $global_cmds " =~ " $arg1 " ]]; then
        # labber <svc> <cmd>: complete with service commands
        COMPREPLY=( $(compgen -W "$svc_cmds" -- "$cur") )
    fi
}
complete -F _labber_complete labber
BASHRC
    ok "tab completion updated in $rc"
}

do_self_install() {
    command -v curl &>/dev/null || die "curl is required for self-install"
    local sudo_cmd=""
    (( EUID == 0 )) || sudo_cmd="sudo"
    if [[ -f "$LABBER_BIN" ]]; then
        local ans; read -rp "labber already installed at $LABBER_BIN. Overwrite? [y/N] " ans
        [[ "$ans" =~ ^[Yy]$ ]] || { info "aborted"; return; }
    fi
    info "installing labber to $LABBER_BIN..."
    curl -fsSL "$LABBER_URL" | $sudo_cmd tee "$LABBER_BIN" > /dev/null && $sudo_cmd chmod 755 "$LABBER_BIN"
    ok "labber installed to $LABBER_BIN"
    _install_shell_fn
    local ans; read -rp "Enable tab completion? [Y/n] " ans
    [[ "$ans" =~ ^[Nn]$ ]] || _install_completion_fn
    warn "run 'source ~/.bashrc' or open a new terminal to activate"
}

do_update() {
    local sudo_cmd=""
    (( EUID == 0 )) || sudo_cmd="sudo"

    info "running system update..."
    $sudo_cmd apt update && $sudo_cmd apt upgrade -y
    ok "system updated"
    echo
    if [[ ! -f "$LABBER_BIN" ]]; then
        warn "labber not installed at $LABBER_BIN"
        local ans; read -rp "Install now? [Y/n] " ans
        [[ "$ans" =~ ^[Nn]$ ]] || do_self_install
        return
    fi
    info "checking for labber update..."
    if ! command -v curl &>/dev/null; then
        warn "curl not found — skipping labber self-update"
        return
    fi
    local tmp; tmp=$(mktemp /tmp/labber-update-XXXXXX)
    if ! curl -fsSL "$LABBER_URL" -o "$tmp" 2>/dev/null; then
        rm -f "$tmp"
        warn "labber self-update failed (network issue?) — binary unchanged"
        return
    fi
    local remote_ver; remote_ver=$(grep -m1 '^VERSION=' "$tmp" | cut -d'"' -f2)
    if [[ "$remote_ver" == "$VERSION" ]]; then
        ok "labber already on latest (v${VERSION})"
        rm -f "$tmp"
        return
    fi
    $sudo_cmd mv -f "$tmp" "$LABBER_BIN" && $sudo_cmd chmod 755 "$LABBER_BIN"
    ok "labber updated: v${VERSION} → v${remote_ver}"
    echo
    info "checking shell integration..."
    _install_shell_fn
    _install_completion_fn
    warn "run 'source ~/.bashrc' to apply any changes"
}

do_clean() {
    check_deps
    warn "this will remove ALL unused containers, images, networks, and volumes"
    local ans; read -rp "Confirm [y/N] " ans
    [[ "$ans" =~ ^[Yy]$ ]] || { info "aborted"; return; }
    docker system prune -af --volumes
    ok "docker cleaned"
}

do_ls() {
    local svcs; mapfile -t svcs < <(list_installed)
    if (( ${#svcs[@]} == 0 )); then
        warn "no services installed under $SERVICE_BASE"
        return
    fi
    echo
    for s in "${svcs[@]}"; do
        local dir; dir=$(svc_dir "$s")
        local running; running=$(cd "$dir" && docker compose ps -q 2>/dev/null | wc -l || echo 0)
        running="${running// /}"
        if (( running > 0 )); then
            printf "  ${G}●${N} %-30s ${G}%s container(s) up${N}\n" "$s" "$running"
        else
            printf "  ${R}●${N} %-30s ${R}stopped${N}\n" "$s"
        fi
    done
}

# ── status overview ───────────────────────────────────────────────────────────

show_overview() {
    local svcs; mapfile -t svcs < <(list_installed)
    if (( ${#svcs[@]} == 0 )); then
        echo -e "  ${Y}no services installed${N}"
        return
    fi
    for s in "${svcs[@]}"; do
        local dir; dir=$(svc_dir "$s")
        local running; running=$(cd "$dir" && docker compose ps -q 2>/dev/null | wc -l || echo 0)
        running="${running// /}"
        if (( running > 0 )); then
            printf "  ${G}●${N} %-30s %s container(s) up\n" "$s" "$running"
        else
            printf "  ${R}●${N} %-30s stopped\n" "$s"
        fi
    done
}

# ── interactive menu ──────────────────────────────────────────────────────────

show_menu() {
    echo -e "\n${W}${B}labber v${VERSION} — homelab service manager${N}\n"
    echo -e "${W}installed services:${N}"
    show_overview
    echo

    local cmds=(  deploy  uninstall  start  stop  restart  rebuild  shell  logs  status  ls  go  clean  update )
    local descs=(
        "deploy a service from repo"
        "stop and remove a service"
        "start service containers"
        "stop service containers"
        "restart service containers"
        "full rebuild: down + prune + pull + up"
        "enter a running container shell"
        "follow service logs"
        "show container status"
        "list installed services and status"
        "go to service directory"
        "remove all unused containers, images, volumes"
        "system apt update + upgrade labber"
    )

    echo -e "${W}commands:${N}"
    for i in "${!cmds[@]}"; do
        printf "  %2d) %-12s %s\n" "$((i+1))" "${cmds[$i]}" "${descs[$i]}"
    done
    echo

    local n
    while true; do
        read -rp "choice [1-${#cmds[@]}] or q to quit: " n
        [[ "$n" == "q" || "$n" == "Q" ]] && exit 0
        [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= ${#cmds[@]} )) && break
        warn "invalid choice"
    done
    local chosen="${cmds[$((n-1))]}"
    [[ "$chosen" == "deploy" ]] && { do_install ""; return; }
    "do_${chosen//-/_}" ""
}

# ── usage ─────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
${W}labber v${VERSION}${N} — homelab service manager

${W}Usage:${N}
  labber [svc] <command>

${W}Commands:${N}
  [svc] uninstall   stop and remove a service
  [svc] start       docker compose start
  [svc] stop        docker compose stop
  [svc] restart     docker compose restart
  [svc] rebuild     full rebuild: down + system prune + pull + up
  [svc] shell       enter a running container shell
  [svc] logs        follow docker compose logs
  [svc] status      show container status
  [svc] go          cd to service directory
  ls                list installed services and status
  clean             remove all unused containers, images, networks, and volumes
  update            system apt update + upgrade + labber self-update
  install           install labber to /usr/local/bin + shell function
  (no args)         interactive menu

${W}Note:${N}
  'labber <svc> go' requires the shell function installed by 'labber install'.
  After install, run: source ~/.bashrc

${W}One-liner install on any LXC:${N}
  bash <(curl -fsSL https://raw.githubusercontent.com/rahulsrma26/homelab/refs/heads/main/services/labber)
EOF
}

# ── main ──────────────────────────────────────────────────────────────────────

SVC="${1:-}"; shift 2>/dev/null || true
CMD="${1:-}"; shift 2>/dev/null || true

# Global commands have no service prefix — detect when SVC slot holds a global cmd
_GLOBAL_CMDS="install ls clean update help -h --help"
if [[ " $_GLOBAL_CMDS " =~ " $SVC " ]]; then
    _tmp="$CMD"; CMD="$SVC"; SVC="$_tmp"
elif [[ -z "$CMD" ]]; then
    CMD="$SVC"; SVC=""
fi

case "$CMD" in
    install)   do_self_install ;;
    uninstall) do_uninstall "$SVC" ;;
    start)     do_start     "$SVC" ;;
    stop)      do_stop      "$SVC" ;;
    restart)   do_restart   "$SVC" ;;
    rebuild)   do_rebuild   "$SVC" ;;
    shell)     do_shell     "$SVC" ;;
    logs)      do_logs      "$SVC" ;;
    status)    do_status    "$SVC" ;;
    ls)        do_ls ;;
    go)        do_go        "$SVC" ;;
    clean)     do_clean ;;
    update)    do_update ;;
    help|-h|--help) usage ;;
    "")        show_menu ;;
    *) die "unknown command '$CMD' — run: labber help" ;;
esac
