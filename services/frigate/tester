#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"

SHOW_URL=false

usage() {
    echo "Usage: tester [-s|--show] <CAMERA_NAME>"
    echo "       tester CAMERA1"
    echo "       tester --show DOORBELL"
    exit 1
}

# Parse args
POSITIONAL=()
for arg in "$@"; do
    case "$arg" in
        -s|--show) SHOW_URL=true ;;
        -*) usage ;;
        *) POSITIONAL+=("$arg") ;;
    esac
done
[[ ${#POSITIONAL[@]} -eq 1 ]] || usage
CAMERA="${POSITIONAL[0]^^}"

[[ -f "$ENV_FILE" ]] || { echo "error: .env not found at $ENV_FILE"; exit 1; }

set -a; source "$ENV_FILE"; set +a

ip_var="FRIGATE_${CAMERA}_IP"
user_var="FRIGATE_${CAMERA}_USER"
pass_var="FRIGATE_${CAMERA}_PSWD"
main_var="FRIGATE_${CAMERA}_MAIN"
sub_var="FRIGATE_${CAMERA}_SUB"

ip="${!ip_var:-}"
user="${!user_var:-}"
pass="${!pass_var:-}"
main_stream="${!main_var:-}"
sub_stream="${!sub_var:-}"

[[ -n "$ip" ]]          || { echo "error: $ip_var not set in .env"; exit 1; }
[[ -n "$user" ]]        || { echo "error: $user_var not set in .env"; exit 1; }
[[ -n "$pass" ]]        || { echo "error: $pass_var not set in .env"; exit 1; }
[[ -n "$main_stream" ]] || { echo "error: $main_var not set in .env"; exit 1; }
[[ -n "$sub_stream" ]]  || { echo "error: $sub_var not set in .env"; exit 1; }

probe() {
    local label="$1" url="$2"
    echo "+-- $label"
    $SHOW_URL && echo "  | $url"
    ffprobe -v quiet -print_format json -show_streams \
        -rtsp_transport tcp "$url" 2>&1 \
        | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    for s in data.get('streams', []):
        idx   = s.get('index', '?')
        ctype = s.get('codec_type', '?')
        codec = s.get('codec_name', '?')
        if ctype == 'video':
            w   = s.get('width', '?')
            h   = s.get('height', '?')
            fps = s.get('r_frame_rate', '?')
            print(f'  | Stream #{idx}: {ctype} — {codec} {w}x{h} @ {fps} fps')
        elif ctype == 'audio':
            sr  = s.get('sample_rate', '?')
            ch  = s.get('channels', '?')
            print(f'  | Stream #{idx}: {ctype} — {codec} {sr}Hz {ch}ch')
        else:
            print(f'  | Stream #{idx}: {ctype} — {codec}')
except Exception as e:
    print(f'  | error: {e}')
    sys.exit(1)
" || echo "  | ffprobe failed — check IP, credentials, or stream path"
}

echo "Camera: $CAMERA ($ip)"
probe "Main  ($main_stream)" "rtsp://$user:$pass@$ip:554/$main_stream"
probe "Sub   ($sub_stream)"  "rtsp://$user:$pass@$ip:554/$sub_stream"
