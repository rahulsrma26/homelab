CONFIG_DIR=./config
STORAGE_DIR=/mnt/nvr
FRIGATE_RTSP_PASSWORD=changeme

# shm_size — increase for more cameras or higher resolution
# Formula: (width * height * 1.5 * 20 + 270480) / 1048576 + 40 MB per camera
# 1x 1080p ≈ 93MB, 4x 1080p ≈ 412MB
SHM_SIZE=512mb

HTTP_PORT=8971
RTSP_PORT=8554
WEBRTC_PORT=8555
